# Copia este archivo a .env y ajusta los valores para desarrollo local.
# NUNCA commitear .env real.

# --- Postgres (PMS) ---
POSTGRES_USER=pms
POSTGRES_PASSWORD=pms_dev_password
POSTGRES_DB=pms
DATABASE_URL=postgresql://pms:pms_dev_password@localhost:5432/pms

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_dev_password
KEYCLOAK_DB_PASSWORD=keycloak_dev_password
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=pms
KEYCLOAK_CLIENT_ID=pms-api

# --- NATS ---
NATS_URL=nats://localhost:4222

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Anthropic (IA) ---
ANTHROPIC_API_KEY=

# --- App ---
NODE_ENV=development
LOG_LEVEL=debug
APP_PORT=3000
