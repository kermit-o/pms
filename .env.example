# Copia este archivo a .env y ajusta los valores para desarrollo local.
# NUNCA commitear .env real.

# --- Postgres (PMS) ---
POSTGRES_USER=pms
POSTGRES_PASSWORD=pms_dev_password
POSTGRES_DB=pms

# La API se conecta como pms_app (rol sin BYPASSRLS — las policies RLS aplican).
DATABASE_URL=postgresql://pms_app:pms_app_dev_password@localhost:5432/pms

# Migraciones, seeds y operaciones de admin se conectan como pms (OWNER, superuser)
# para crear tablas, ejecutar GRANTs y poder INSERT en seed sin tener que setear
# app.tenant_id. Prisma usa DIRECT_URL para migrate/db push/studio.
DIRECT_URL=postgresql://pms:pms_dev_password@localhost:5432/pms

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_dev_password
KEYCLOAK_DB_PASSWORD=keycloak_dev_password
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=pms
KEYCLOAK_CLIENT_ID=pms-api
# Secret usado para el grant directo desde tests/scripts. La API solo
# valida JWTs via JWKS publica, no necesita el secret en runtime.
KEYCLOAK_CLIENT_SECRET=pms-api-dev-secret

# Demo user creado por scripts/keycloak-bootstrap.ts
DEMO_USER_EMAIL=admin@demo.local
DEMO_USER_PASSWORD=demo123

# --- NATS ---
NATS_URL=nats://localhost:4222

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Anthropic (IA) ---
ANTHROPIC_API_KEY=

# --- Observability (OpenTelemetry) ---
# OTEL_ENABLED=false desactiva todo (util en tests).
OTEL_ENABLED=true
# Si esta vacio: trazas en memoria sin exportar (trace_id propaga en logs).
# Para exportar a Jaeger/Tempo/OTel Collector: ej. http://localhost:4318
OTEL_EXPORTER_OTLP_ENDPOINT=
# Prometheus metrics: scrape http://localhost:9464/metrics
OTEL_METRICS_PORT=9464

# --- App ---
NODE_ENV=development
LOG_LEVEL=debug
APP_PORT=3000
