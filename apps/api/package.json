{
  "name": "@pms/api",
  "version": "0.0.0",
  "private": true,
  "description": "PMS API — NestJS backend (REST + MCP, multi-tenant)",
  "main": "dist/main.js",
  "type": "commonjs",
  "scripts": {
    "clean": "rm -rf dist .nest *.tsbuildinfo",
    "prebuild": "pnpm clean",
    "build": "nest build",
    "predev": "pnpm --dir ../../packages/db build && pnpm --dir ../../packages/eventbus build && pnpm --dir ../../packages/mcp-tools build",
    "dev": "ts-node-dev --respawn --transpile-only --no-notify -r tsconfig-paths/register src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@aws-sdk/client-s3": "^3.1044.0",
    "@aws-sdk/s3-request-presigner": "^3.1044.0",
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-fastify": "^10.4.4",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.55.0",
    "@opentelemetry/exporter-prometheus": "^0.55.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.55.0",
    "@opentelemetry/resources": "^1.28.0",
    "@opentelemetry/sdk-node": "^0.55.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@pms/db": "workspace:*",
    "@pms/eventbus": "workspace:*",
    "@pms/mcp-tools": "workspace:*",
    "@prisma/client": "^5.22.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "fastify": "^4.28.1",
    "jose": "^5.9.6",
    "nats": "^2.29.0",
    "nestjs-pino": "^4.1.0",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.2.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.4",
    "@swc/core": "^1.7.36",
    "@types/node": "^20.16.10",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3",
    "unplugin-swc": "^1.5.1",
    "vitest": "^2.1.2"
  }
}
