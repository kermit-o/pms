# Aubergine HSK PWA — local dev defaults.
# Copy to .env.local and fill in.

# NextAuth
AUTH_SECRET=replace-me-with-openssl-rand-hex-32
AUTH_TRUST_HOST=true

# Keycloak (separate client for HSK; same realm as web-fo)
KEYCLOAK_ISSUER=http://localhost:8080/realms/pms
KEYCLOAK_CLIENT_ID=pms-hsk
KEYCLOAK_CLIENT_SECRET=

# Aubergine API
NEXT_PUBLIC_API_URL=http://localhost:3000
