# Aubergine FO web — local dev defaults.
# Copy to .env.local and fill in.

# NextAuth
AUTH_SECRET=replace-me-with-openssl-rand-hex-32
AUTH_TRUST_HOST=true

# Keycloak (issuer = realm URL, no trailing slash)
KEYCLOAK_ISSUER=http://localhost:8080/realms/pms
KEYCLOAK_CLIENT_ID=pms-web
KEYCLOAK_CLIENT_SECRET=

# Aubergine API
NEXT_PUBLIC_API_URL=http://localhost:3000
