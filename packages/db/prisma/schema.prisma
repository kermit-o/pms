// ----------------------------------------------------------------------------
// Copilot messages — audit trail + cost observability. Sprint 6 W1.
// Una fila por turn: USER, ASSISTANT, TOOL_USE, TOOL_RESULT. Persistido en
// caliente (cada turno); rotacion via job NA cuando la politica del tenant
// lo exija. Ver docs/SPRINT-6-PLAN.md §2.2.
// ----------------------------------------------------------------------------

model CopilotMessage {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String             @map("tenant_id") @db.Uuid
  sessionId        String             @map("session_id") @db.Uuid
  userId           String             @map("user_id") @db.Uuid
  role             CopilotMessageRole
  contentText      String?            @map("content_text")
  toolName         String?            @map("tool_name")
  toolInput        Json?              @map("tool_input")
  toolResult       Json?              @map("tool_result")
  model            String?
  inputTokens      Int?               @map("input_tokens")
  outputTokens     Int?               @map("output_tokens")
  cacheReadTokens  Int?               @map("cache_read_tokens")
  cacheWriteTokens Int?               @map("cache_write_tokens")
  latencyMs        Int?               @map("latency_ms")
  createdAt        DateTime           @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([tenantId, createdAt])
  @@map("copilot_messages")
}

enum CopilotMessageRole {
  USER
  ASSISTANT
  TOOL_USE
  TOOL_RESULT

  @@map("copilot_message_role")
}

// ----------------------------------------------------------------------------
// Guest memory (Sprint 7 W2). Chunks de texto del huesped indexados con
// tsvector. La columna tsv vive en SQL como GENERATED ALWAYS y no se mapea
// aqui — las queries de ranking van por $queryRaw.
// ----------------------------------------------------------------------------

model GuestMemoryChunk {
  id            String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String                @map("tenant_id") @db.Uuid
  guestId       String                @map("guest_id") @db.Uuid
  sourceKind    GuestMemorySourceKind @map("source_kind")
  sourceRef     String?               @map("source_ref")
  chunkText     String                @map("chunk_text")
  vectorPending Boolean               @default(true) @map("vector_pending")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  guest  Guest  @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@unique([guestId, sourceKind, sourceRef])
  @@index([tenantId, guestId])
  @@map("guest_memory_chunks")
}

enum GuestMemorySourceKind {
  CARDEX
  STAY_NOTE
  FOLIO_NOTE
  SPECIAL_REQUEST

  @@map("guest_memory_source_kind")
}

// ============================================================================
// Sprint 11 W1 — Email suppression list
//
// Lista global (no por tenant) de emails que no deben recibir notificaciones
// transaccionales. Se alimenta de:
//  - bounces duros de Postmark via webhook
//  - quejas de spam (SpamComplaint)
//  - unsubscribe explícito (SubscriptionChange con SuppressSending=true)
//  - bajas manuales de soporte
//
// Es global porque la reputación del dominio remitente es del SaaS, no del
// hotel: si un email hace bounce duro, no deberíamos volver a intentarlo
// desde otro tenant.
// ============================================================================

model EmailSuppression {
  email     String              @id @db.Citext
  reason    EmailSuppressionReason
  detail    String?
  source    String              @default("postmark")
  createdAt DateTime            @default(now()) @map("created_at")

  @@map("email_suppressions")
}

enum EmailSuppressionReason {
  HARD_BOUNCE
  SPAM_COMPLAINT
  UNSUBSCRIBE
  MANUAL

  @@map("email_suppression_reason")
}

// ============================================================================
// Sprint 11 W2 — Notification outbox
//
// Auditoría + dedup del consumer NATS de emails. Una fila por evento
// `email.send_requested` procesado. `dedupKey` = envelope.id (UUID v4 del
// publisher); consumers re-entregados consultan esta tabla antes de
// reenviar a Postmark.
// ============================================================================

model NotificationOutbox {
  id          String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dedupKey    String                @unique @map("dedup_key")
  template    String
  recipient   String                @db.Citext
  locale      String                @default("es")
  params      Json
  status      NotificationOutboxStatus @default(PENDING)
  attempts    Int                   @default(0)
  lastError   String?               @map("last_error")
  messageId   String?               @map("message_id")
  createdAt   DateTime              @default(now()) @map("created_at")
  deliveredAt DateTime?             @map("delivered_at")
  failedAt    DateTime?             @map("failed_at")

  @@index([status, createdAt])
  @@map("notification_outbox")
}

enum NotificationOutboxStatus {
  PENDING
  DELIVERED
  FAILED
  SUPPRESSED

  @@map("notification_outbox_status")
}
