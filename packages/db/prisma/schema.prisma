// PMS — Database schema
// Multi-tenant. RLS enforces isolation at Postgres level (see migrations/*/migration.sql).
// Cada tabla operativa lleva tenant_id; las politicas usan current_setting('app.tenant_id').

generator client {
  provider      = "prisma-client-js"
  // 'native' para dev local (Codespace ubuntu glibc).
  // 'linux-musl-openssl-3.0.x' para el runtime Docker (node:20-alpine + openssl 3).
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ----------------------------------------------------------------------------
// Tenants — un tenant = un hotel (single-property en MVP).
// La tabla tenants NO tiene RLS (es admin-level). Exposicion controlada por API.
// ----------------------------------------------------------------------------

model Tenant {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug             String       @unique
  name             String
  status           TenantStatus @default(TRIAL)
  // Onboarding wizard (Sprint 9 W3): rastrea el estado del self-service.
  // NULL en tenants creados manualmente / seeded. Para hoteles activos en
  // producción, esto se ignora — solo describe el origen.
  onboardingStatus String?      @map("onboarding_status")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  deletedAt        DateTime?    @map("deleted_at")

  users              User[]
  properties         Property[]
  roomTypes          RoomType[]
  rooms              Room[]
  guests             Guest[]
  reservations       Reservation[]
  reservationGroups  ReservationGroup[]
  reservationGuests  ReservationGuest[]
  ratePlans          RatePlan[]
  folios             Folio[]
  folioEntries       FolioEntry[]
  businessDays        BusinessDayState[]
  sesSubmissions      SesHospedajesSubmission[]
  nightAuditRuns      NightAuditRun[]
  nightAuditRunSteps  NightAuditRunStep[]
  nightAuditSnapshots NightAuditSnapshot[]
  nightAuditAnomalies NightAuditAnomaly[]
  cashReconciliations CashDrawerReconciliation[]
  housekeepingTasks   HousekeepingTask[]
  lostFoundItems      LostFoundItem[]
  devicePairings      DevicePairing[]
  cancellationPolicies CancellationPolicy[]
  copilotMessages     CopilotMessage[]
  guestMemoryChunks   GuestMemoryChunk[]

  @@map("tenants")
}

enum TenantStatus {
  ACTIVE
  TRIAL
  SUSPENDED

  @@map("tenant_status")
}

// ----------------------------------------------------------------------------
// Users — pertenecen a un tenant. externalId = sub del JWT de Keycloak.
// ----------------------------------------------------------------------------

model User {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String     @map("tenant_id") @db.Uuid
  email      String     @db.Citext
  externalId String?    @map("external_id")
  fullName   String?    @map("full_name")
  status     UserStatus @default(INVITED)
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  deletedAt  DateTime?  @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@unique([tenantId, externalId])
  @@index([tenantId])
  @@map("users")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED

  @@map("user_status")
}

// ----------------------------------------------------------------------------
// Properties — single-property en MVP, multi-property en V2.
// ----------------------------------------------------------------------------

model Property {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  code        String
  name        String
  timezone    String    @default("Europe/Madrid")
  currency    String    @default("EUR")
  locale      String    @default("es-ES")
  // IBE (Sprint 8): slug opaco para venta directa. unique cuando no es null.
  // publishedAt = NULL significa "no expuesto al IBE público".
  publicSlug  String?   @unique @map("public_slug")
  publishedAt DateTime? @map("published_at")
  // Atributos extensibles. Sprint 9 W4 introduce `blockedIps: string[]` para
  // bloqueo manual de IPs abusivas en el IBE. Otros usos futuros: branding
  // de email, configuración de channel manager, etc.
  attributes  Json?
  // Channel manager (Sprint 9 W2). `provider` = identificador del CM ("siteminder",
  // "roomcloud", etc). `propertyId` = id que el CM asigna a este hotel.
  // `credentialsRef` = nombre del secret (Fly) que almacena el API key del CM —
  // nunca el secret en sí mismo en DB.
  channelManagerProvider       String? @map("channel_manager_provider")
  channelManagerPropertyId     String? @map("channel_manager_property_id")
  channelManagerCredentialsRef String? @map("channel_manager_credentials_ref")
  // Atributos extensibles. Sprint 9 W4 introduce `blockedIps: string[]` para
  // bloqueo manual de IPs abusivas en el IBE. Otros usos futuros: branding
  // de email, configuración de channel manager, etc.
  attributes  Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant              Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roomTypes           RoomType[]
  rooms               Room[]
  reservations        Reservation[]
  reservationGroups   ReservationGroup[]
  ratePlans           RatePlan[]
  businessDays        BusinessDayState[]
  sesSubmissions      SesHospedajesSubmission[]
  nightAuditRuns      NightAuditRun[]
  nightAuditSnapshots NightAuditSnapshot[]
  nightAuditAnomalies NightAuditAnomaly[]
  cashReconciliations CashDrawerReconciliation[]
  housekeepingTasks   HousekeepingTask[]
  lostFoundItems      LostFoundItem[]
  cancellationPolicies CancellationPolicy[]
  channelSyncRuns     ChannelSyncRun[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("properties")
}

// ----------------------------------------------------------------------------
// Channel manager sync runs (Sprint 9 W2). Una fila por intento de push o por
// inbound webhook. Sirve para auditoría + dashboards de salud del canal.
// ----------------------------------------------------------------------------

model ChannelSyncRun {
  id          String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String                 @map("tenant_id") @db.Uuid
  propertyId  String                 @map("property_id") @db.Uuid
  provider    String
  kind        ChannelSyncKind
  status      ChannelSyncStatus      @default(IN_PROGRESS)
  startedAt   DateTime               @default(now()) @map("started_at")
  completedAt DateTime?              @map("completed_at")
  error       String?
  // {pushed, received, skipped, idempotent} — totales libres por kind.
  totals      Json?
  // Para inbound: id que el provider asigna a la reserva original (idempotency).
  externalRef String?                @map("external_ref")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([tenantId, propertyId, startedAt])
  @@index([tenantId, status])
  @@map("channel_sync_runs")
}

enum ChannelSyncKind {
  PUSH_AVAILABILITY
  PUSH_RATES
  PULL_RESERVATION
  NIGHTLY_FULL

  @@map("channel_sync_kind")
}

enum ChannelSyncStatus {
  IN_PROGRESS
  OK
  FAILED
  SKIPPED

  @@map("channel_sync_status")
}

// ----------------------------------------------------------------------------
// AuditLog — append-only via triggers (ver migracion).
// SELECT filtrado por tenant via RLS. INSERT/UPDATE/DELETE bloqueados para la app.
// ----------------------------------------------------------------------------

model AuditLog {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  tableName     String         @map("table_name")
  recordId      String         @map("record_id") @db.Uuid
  operation     AuditOperation
  actorId       String?        @map("actor_id") @db.Uuid
  correlationId String?        @map("correlation_id")
  oldData       Json?          @map("old_data")
  newData       Json?          @map("new_data")
  changedAt     DateTime       @default(now()) @map("changed_at")

  @@index([tenantId, tableName, recordId])
  @@index([tenantId, changedAt])
  @@map("audit_log")
}

enum AuditOperation {
  INSERT
  UPDATE
  DELETE

  @@map("audit_operation")
}

// ============================================================================
// Sprint 2 pre-work — modelo de datos canonico de Front Office.
//
// El alcance funcional (workflows, edges cases) se ajusta tras hablar con
// 2-3 hoteles boutique (per ADR-007). Las entidades y campos base aqui
// son universales en la industria PMS y se confirman en la mayoria de
// hoteles, pero los enums (status, source) y los campos en `attributes`
// (jsonb) se pueden extender sin migracion.
// ============================================================================

// ----------------------------------------------------------------------------
// Inventario fisico: tipos de habitacion + habitaciones individuales.
// ----------------------------------------------------------------------------

model RoomType {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  propertyId      String    @map("property_id") @db.Uuid
  code            String // "STD", "DLX", "SUI"
  name            String
  description     String?
  baseOccupancy   Int       @default(2) @map("base_occupancy")
  maxOccupancy    Int       @default(2) @map("max_occupancy")
  defaultRate     Decimal   @default(0) @map("default_rate") @db.Decimal(12, 2)
  defaultCurrency String    @default("EUR") @map("default_currency") @db.Char(3)
  // Atributos hotel-especificos (m2, bed config, amenities) hasta que se
  // confirme con feedback si necesitan estructura propia.
  attributes      Json?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  rooms        Room[]
  reservations Reservation[]

  @@unique([tenantId, propertyId, code])
  @@index([tenantId, propertyId])
  @@map("room_types")
}

model Room {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String     @map("tenant_id") @db.Uuid
  propertyId       String     @map("property_id") @db.Uuid
  roomTypeId       String     @map("room_type_id") @db.Uuid
  number           String // "101", "201A"
  floor            String?
  status           RoomStatus @default(CLEAN)
  isOutOfOrder     Boolean    @default(false) @map("is_out_of_order")
  outOfOrderReason String?    @map("out_of_order_reason")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  deletedAt        DateTime?  @map("deleted_at")

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property          Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomType          RoomType           @relation(fields: [roomTypeId], references: [id])
  reservations      Reservation[]
  housekeepingTasks HousekeepingTask[]
  lostFoundItems    LostFoundItem[]

  @@unique([tenantId, propertyId, number])
  @@index([tenantId, propertyId])
  @@index([tenantId, roomTypeId])
  @@map("rooms")
}

enum RoomStatus {
  CLEAN
  DIRTY
  INSPECTED
  OUT_OF_ORDER
  OUT_OF_SERVICE

  @@map("room_status")
}

// ----------------------------------------------------------------------------
// Cardex de huespedes (compliance ES + GDPR).
// Documentos: DNI/NIE/PASSPORT obligatorios para SES.HOSPEDAJES.
// ----------------------------------------------------------------------------

model Guest {
  id                     String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId               String        @map("tenant_id") @db.Uuid
  // Identificacion
  firstName              String        @map("first_name")
  lastName               String        @map("last_name")
  email                  String?       @db.Citext
  phone                  String?
  dateOfBirth            DateTime?     @map("date_of_birth") @db.Date
  // Documento (cardex / SES.HOSPEDAJES)
  documentType           DocumentType? @map("document_type")
  documentNumber         String?       @map("document_number")
  documentIssuingCountry String?       @map("document_issuing_country") @db.Char(2)
  documentExpiryDate     DateTime?     @map("document_expiry_date") @db.Date
  nationality            String?       @db.Char(2)
  // Direccion
  addressLine1           String?       @map("address_line1")
  addressLine2           String?       @map("address_line2")
  city                   String?
  postalCode             String?       @map("postal_code")
  region                 String?
  country                String?       @db.Char(2)
  // GDPR
  gdprConsent            Boolean       @default(false) @map("gdpr_consent")
  marketingConsent       Boolean       @default(false) @map("marketing_consent")
  // Loyalty (Iter B). String libre por ahora: "Gold", "Platinum", "VIP" o lo
  // que el hotel use. Cuando varios hoteles converjan en una taxonomia
  // comun, se puede normalizar a enum.
  membershipLevel        String?       @map("membership_level")
  // Extensible (loyalty, preferencias)
  notes                  String?
  attributes             Json?
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")
  deletedAt              DateTime?     @map("deleted_at")

  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservations   ReservationGuest[]
  lostFoundItems LostFoundItem[]
  memoryChunks   GuestMemoryChunk[]

  @@index([tenantId])
  @@index([tenantId, email])
  @@index([tenantId, documentType, documentNumber])
  @@index([tenantId, lastName, firstName])
  @@map("guests")
}

enum DocumentType {
  DNI
  NIE
  PASSPORT
  EU_ID
  OTHER

  @@map("document_type")
}

// ----------------------------------------------------------------------------
// Plan de tarifas. Estructura minima — restricciones (min stay, advance
// purchase, cancellation policy) en attributes hasta validar con hoteles.
// ----------------------------------------------------------------------------

model RatePlan {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  propertyId  String    @map("property_id") @db.Uuid
  code        String // "BAR", "NRF", "ADV"
  name        String
  description String?
  isPublic    Boolean   @default(true) @map("is_public")
  currency    String    @default("EUR") @db.Char(3)
  attributes  Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@unique([tenantId, propertyId, code])
  @@index([tenantId, propertyId])
  @@map("rate_plans")
}

// ----------------------------------------------------------------------------
// Reservas — la entidad central de Front Office.
// roomId es opcional: la asignacion ocurre en check-in.
// ----------------------------------------------------------------------------

// Bloque de reservas para grupos (boda, congreso, equipo deportivo).
// Las reservas hijas comparten organizador, fechas y politicas; cada una
// mantiene su propio folio y huesped principal.
model ReservationGroup {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  propertyId   String    @map("property_id") @db.Uuid
  code         String // "GRP-WEDDING01"
  name         String
  organizerName  String? @map("organizer_name")
  organizerEmail String? @map("organizer_email")
  organizerPhone String? @map("organizer_phone")
  notes        String?
  attributes   Json?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@unique([tenantId, code])
  @@index([tenantId, propertyId])
  @@map("reservation_groups")
}

model Reservation {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String            @map("tenant_id") @db.Uuid
  propertyId         String            @map("property_id") @db.Uuid
  // Codigo legible humano ("BCN-A1B2C3")
  code               String
  status             ReservationStatus @default(PENDING)
  // Grupo opcional (Sprint 2 W2)
  groupId            String?           @map("group_id") @db.Uuid
  // Estancia
  arrivalDate        DateTime          @map("arrival_date") @db.Date
  departureDate      DateTime          @map("departure_date") @db.Date
  adults             Int               @default(2)
  children           Int               @default(0)
  // Inventario
  roomTypeId         String            @map("room_type_id") @db.Uuid
  roomId             String?           @map("room_id") @db.Uuid
  // Precio
  ratePlanId         String?           @map("rate_plan_id") @db.Uuid
  totalAmount        Decimal           @default(0) @map("total_amount") @db.Decimal(12, 2)
  currency           String            @default("EUR") @db.Char(3)
  // Origen
  source             ReservationSource @default(DIRECT)
  externalRef        String?           @map("external_ref")
  // Especiales
  specialRequests    String?           @map("special_requests")
  notes              String?
  // Comercial (Iter B): agencia y empresa del booking, string denormalizado.
  // Catalogo con FK llegara cuando el revenue manager lo justifique.
  agencyName         String?           @map("agency_name")
  companyName        String?           @map("company_name")
  // Lifecycle timestamps
  checkedInAt        DateTime?         @map("checked_in_at")
  checkedOutAt       DateTime?         @map("checked_out_at")
  cancelledAt        DateTime?         @map("cancelled_at")
  cancellationReason String?           @map("cancellation_reason")
  // Garantía comercial (Corte A modelo; gateway Stripe llega en Corte B)
  guaranteeType        GuaranteeType   @default(NONE)            @map("guarantee_type")
  guaranteeStatus      GuaranteeStatus @default(PENDING)         @map("guarantee_status")
  guaranteeAmount      Decimal?        @map("guarantee_amount")  @db.Decimal(12, 2)
  guaranteeReference   String?         @map("guarantee_reference")
  guaranteeDeadline    DateTime?       @map("guarantee_deadline")
  guaranteeSecuredAt   DateTime?       @map("guarantee_secured_at")
  cancellationPolicyId String?         @map("cancellation_policy_id") @db.Uuid
  // Stripe Setup Intent + tokenized payment method (Corte B garantía).
  // Solo guardamos referencias y últimos 4 — el PAN nunca toca nuestros
  // servidores (Stripe es el custodian PCI-compliant).
  stripeCustomerId      String?  @map("stripe_customer_id")
  stripeSetupIntentId   String?  @map("stripe_setup_intent_id")
  stripePaymentMethodId String?  @map("stripe_payment_method_id")
  stripeCardBrand       String?  @map("stripe_card_brand")
  stripeCardLast4       String?  @map("stripe_card_last4") @db.Char(4)
  stripeCardExpMonth    Int?     @map("stripe_card_exp_month") @db.SmallInt
  stripeCardExpYear     Int?     @map("stripe_card_exp_year") @db.SmallInt
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  deletedAt          DateTime?         @map("deleted_at")

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomType RoomType           @relation(fields: [roomTypeId], references: [id])
  room     Room?              @relation(fields: [roomId], references: [id])
  ratePlan RatePlan?          @relation(fields: [ratePlanId], references: [id])
  group    ReservationGroup?  @relation(fields: [groupId], references: [id])
  guests   ReservationGuest[]
  folio    Folio?
  cancellationPolicy CancellationPolicy? @relation(fields: [cancellationPolicyId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId, propertyId, arrivalDate])
  @@index([tenantId, propertyId, departureDate])
  @@index([tenantId, propertyId, status])
  @@index([tenantId, roomId])
  @@index([tenantId, groupId])
  @@index([tenantId, guaranteeStatus])
  @@map("reservations")
}

enum GuaranteeType {
  NONE
  CARD_ON_FILE
  DEPOSIT
  CORPORATE
  HOTEL_GUARANTEE

  @@map("guarantee_type")
}

enum GuaranteeStatus {
  PENDING
  SECURED
  EXPIRED
  FAILED
  RELEASED

  @@map("guarantee_status")
}

model CancellationPolicy {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  propertyId         String   @map("property_id") @db.Uuid
  code               String
  name               String
  hoursBeforeArrival Int      @default(24) @map("hours_before_arrival")
  penaltyPct         Decimal  @default(100) @map("penalty_pct") @db.Decimal(5, 2)
  penaltyMinAmount   Decimal? @map("penalty_min_amount") @db.Decimal(12, 2)
  currency           String   @default("EUR") @db.Char(3)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@unique([tenantId, propertyId, code])
  @@index([tenantId, propertyId])
  @@map("cancellation_policies")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW

  @@map("reservation_status")
}

enum ReservationSource {
  DIRECT
  WALK_IN
  PHONE
  EMAIL
  BOOKING_COM
  EXPEDIA
  OTHER_OTA
  CORPORATE
  AGENT

  @@map("reservation_source")
}

// Una reserva puede tener varios huespedes (familia, grupo).
model ReservationGuest {
  reservationId String  @map("reservation_id") @db.Uuid
  guestId       String  @map("guest_id") @db.Uuid
  tenantId      String  @map("tenant_id") @db.Uuid
  isPrimary     Boolean @default(false) @map("is_primary")

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  guest       Guest       @relation(fields: [guestId], references: [id], onDelete: Cascade)
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([reservationId, guestId])
  @@index([tenantId, guestId])
  @@map("reservation_guests")
}

// ----------------------------------------------------------------------------
// Folio — cuenta financiera por reserva. Append-only via FolioEntry.
// ----------------------------------------------------------------------------

model Folio {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String      @map("tenant_id") @db.Uuid
  reservationId String      @unique @map("reservation_id") @db.Uuid
  status        FolioStatus @default(OPEN)
  balance       Decimal     @default(0) @db.Decimal(12, 2)
  currency      String      @default("EUR") @db.Char(3)
  closedAt      DateTime?   @map("closed_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservation Reservation  @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  entries     FolioEntry[]

  @@index([tenantId, reservationId])
  @@map("folios")
}

enum FolioStatus {
  OPEN
  CLOSED
  SETTLED

  @@map("folio_status")
}

model FolioEntry {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  folioId        String         @map("folio_id") @db.Uuid
  type           FolioEntryType
  description    String
  amount         Decimal        @db.Decimal(12, 2)
  currency       String         @default("EUR") @db.Char(3)
  postedAt       DateTime       @default(now()) @map("posted_at")
  postedBy       String?        @map("posted_by") @db.Uuid
  idempotencyKey String?        @map("idempotency_key")
  attributes     Json?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  folio  Folio  @relation(fields: [folioId], references: [id], onDelete: Cascade)

