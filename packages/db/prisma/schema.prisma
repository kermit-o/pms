// PMS — Database schema
// Multi-tenant. RLS enforces isolation at Postgres level (see migrations/*/migration.sql).
// Cada tabla operativa lleva tenant_id; las politicas usan current_setting('app.tenant_id').

generator client {
  provider      = "prisma-client-js"
  // 'native' para dev local (Codespace ubuntu glibc).
  // 'linux-musl-openssl-3.0.x' para el runtime Docker (node:20-alpine + openssl 3).
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ----------------------------------------------------------------------------
// Tenants — un tenant = un hotel (single-property en MVP).
// La tabla tenants NO tiene RLS (es admin-level). Exposicion controlada por API.
// ----------------------------------------------------------------------------

model Tenant {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug      String       @unique
  name      String
  status    TenantStatus @default(TRIAL)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  deletedAt DateTime?    @map("deleted_at")

  users              User[]
  properties         Property[]
  roomTypes          RoomType[]
  rooms              Room[]
  guests             Guest[]
  reservations       Reservation[]
  reservationGroups  ReservationGroup[]
  reservationGuests  ReservationGuest[]
  ratePlans          RatePlan[]
  folios             Folio[]
  folioEntries       FolioEntry[]
  businessDays        BusinessDayState[]
  sesSubmissions      SesHospedajesSubmission[]
  nightAuditRuns      NightAuditRun[]
  nightAuditRunSteps  NightAuditRunStep[]
  nightAuditSnapshots NightAuditSnapshot[]
  cashReconciliations CashDrawerReconciliation[]
  housekeepingTasks   HousekeepingTask[]
  lostFoundItems      LostFoundItem[]
  devicePairings      DevicePairing[]

  @@map("tenants")
}

enum TenantStatus {
  ACTIVE
  TRIAL
  SUSPENDED

  @@map("tenant_status")
}

// ----------------------------------------------------------------------------
// Users — pertenecen a un tenant. externalId = sub del JWT de Keycloak.
// ----------------------------------------------------------------------------

model User {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String     @map("tenant_id") @db.Uuid
  email      String     @db.Citext
  externalId String?    @map("external_id")
  fullName   String?    @map("full_name")
  status     UserStatus @default(INVITED)
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  deletedAt  DateTime?  @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@unique([tenantId, externalId])
  @@index([tenantId])
  @@map("users")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED

  @@map("user_status")
}

// ----------------------------------------------------------------------------
// Properties — single-property en MVP, multi-property en V2.
// ----------------------------------------------------------------------------

model Property {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  code      String
  name      String
  timezone  String    @default("Europe/Madrid")
  currency  String    @default("EUR")
  locale    String    @default("es-ES")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant              Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roomTypes           RoomType[]
  rooms               Room[]
  reservations        Reservation[]
  reservationGroups   ReservationGroup[]
  ratePlans           RatePlan[]
  businessDays        BusinessDayState[]
  sesSubmissions      SesHospedajesSubmission[]
  nightAuditRuns      NightAuditRun[]
  nightAuditSnapshots NightAuditSnapshot[]
  cashReconciliations CashDrawerReconciliation[]
  housekeepingTasks   HousekeepingTask[]
  lostFoundItems      LostFoundItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("properties")
}

// ----------------------------------------------------------------------------
// AuditLog — append-only via triggers (ver migracion).
// SELECT filtrado por tenant via RLS. INSERT/UPDATE/DELETE bloqueados para la app.
// ----------------------------------------------------------------------------

model AuditLog {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  tableName     String         @map("table_name")
  recordId      String         @map("record_id") @db.Uuid
  operation     AuditOperation
  actorId       String?        @map("actor_id") @db.Uuid
  correlationId String?        @map("correlation_id")
  oldData       Json?          @map("old_data")
  newData       Json?          @map("new_data")
  changedAt     DateTime       @default(now()) @map("changed_at")

  @@index([tenantId, tableName, recordId])
  @@index([tenantId, changedAt])
  @@map("audit_log")
}

enum AuditOperation {
  INSERT
  UPDATE
  DELETE

  @@map("audit_operation")
}

// ============================================================================
// Sprint 2 pre-work — modelo de datos canonico de Front Office.
//
// El alcance funcional (workflows, edges cases) se ajusta tras hablar con
// 2-3 hoteles boutique (per ADR-007). Las entidades y campos base aqui
// son universales en la industria PMS y se confirman en la mayoria de
// hoteles, pero los enums (status, source) y los campos en `attributes`
// (jsonb) se pueden extender sin migracion.
// ============================================================================

// ----------------------------------------------------------------------------
// Inventario fisico: tipos de habitacion + habitaciones individuales.
// ----------------------------------------------------------------------------

model RoomType {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  propertyId      String    @map("property_id") @db.Uuid
  code            String // "STD", "DLX", "SUI"
  name            String
  description     String?
  baseOccupancy   Int       @default(2) @map("base_occupancy")
  maxOccupancy    Int       @default(2) @map("max_occupancy")
  defaultRate     Decimal   @default(0) @map("default_rate") @db.Decimal(12, 2)
  defaultCurrency String    @default("EUR") @map("default_currency") @db.Char(3)
  // Atributos hotel-especificos (m2, bed config, amenities) hasta que se
  // confirme con feedback si necesitan estructura propia.
  attributes      Json?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  rooms        Room[]
  reservations Reservation[]

  @@unique([tenantId, propertyId, code])
  @@index([tenantId, propertyId])
  @@map("room_types")
}

model Room {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String     @map("tenant_id") @db.Uuid
  propertyId       String     @map("property_id") @db.Uuid
  roomTypeId       String     @map("room_type_id") @db.Uuid
  number           String // "101", "201A"
  floor            String?
  status           RoomStatus @default(CLEAN)
  isOutOfOrder     Boolean    @default(false) @map("is_out_of_order")
  outOfOrderReason String?    @map("out_of_order_reason")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  deletedAt        DateTime?  @map("deleted_at")

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property          Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomType          RoomType           @relation(fields: [roomTypeId], references: [id])
  reservations      Reservation[]
  housekeepingTasks HousekeepingTask[]
  lostFoundItems    LostFoundItem[]

  @@unique([tenantId, propertyId, number])
  @@index([tenantId, propertyId])
  @@index([tenantId, roomTypeId])
  @@map("rooms")
}

enum RoomStatus {
  CLEAN
  DIRTY
  INSPECTED
  OUT_OF_ORDER
  OUT_OF_SERVICE

  @@map("room_status")
}

// ----------------------------------------------------------------------------
// Cardex de huespedes (compliance ES + GDPR).
// Documentos: DNI/NIE/PASSPORT obligatorios para SES.HOSPEDAJES.
// ----------------------------------------------------------------------------

model Guest {
  id                     String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId               String        @map("tenant_id") @db.Uuid
  // Identificacion
  firstName              String        @map("first_name")
  lastName               String        @map("last_name")
  email                  String?       @db.Citext
  phone                  String?
  dateOfBirth            DateTime?     @map("date_of_birth") @db.Date
  // Documento (cardex / SES.HOSPEDAJES)
  documentType           DocumentType? @map("document_type")
  documentNumber         String?       @map("document_number")
  documentIssuingCountry String?       @map("document_issuing_country") @db.Char(2)
  documentExpiryDate     DateTime?     @map("document_expiry_date") @db.Date
  nationality            String?       @db.Char(2)
  // Direccion
  addressLine1           String?       @map("address_line1")
  addressLine2           String?       @map("address_line2")
  city                   String?
  postalCode             String?       @map("postal_code")
  region                 String?
  country                String?       @db.Char(2)
  // GDPR
  gdprConsent            Boolean       @default(false) @map("gdpr_consent")
  marketingConsent       Boolean       @default(false) @map("marketing_consent")
  // Extensible (loyalty, preferencias)
  notes                  String?
  attributes             Json?
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")
  deletedAt              DateTime?     @map("deleted_at")

  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservations   ReservationGuest[]
  lostFoundItems LostFoundItem[]

  @@index([tenantId])
  @@index([tenantId, email])
  @@index([tenantId, documentType, documentNumber])
  @@index([tenantId, lastName, firstName])
  @@map("guests")
}

enum DocumentType {
  DNI
  NIE
  PASSPORT
  EU_ID
  OTHER

  @@map("document_type")
}

// ----------------------------------------------------------------------------
// Plan de tarifas. Estructura minima — restricciones (min stay, advance
// purchase, cancellation policy) en attributes hasta validar con hoteles.
// ----------------------------------------------------------------------------

model RatePlan {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  propertyId  String    @map("property_id") @db.Uuid
  code        String // "BAR", "NRF", "ADV"
  name        String
  description String?
  isPublic    Boolean   @default(true) @map("is_public")
  currency    String    @default("EUR") @db.Char(3)
  attributes  Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@unique([tenantId, propertyId, code])
  @@index([tenantId, propertyId])
  @@map("rate_plans")
}

// ----------------------------------------------------------------------------
// Reservas — la entidad central de Front Office.
// roomId es opcional: la asignacion ocurre en check-in.
// ----------------------------------------------------------------------------

// Bloque de reservas para grupos (boda, congreso, equipo deportivo).
// Las reservas hijas comparten organizador, fechas y politicas; cada una
// mantiene su propio folio y huesped principal.
model ReservationGroup {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  propertyId   String    @map("property_id") @db.Uuid
  code         String // "GRP-WEDDING01"
  name         String
  organizerName  String? @map("organizer_name")
  organizerEmail String? @map("organizer_email")
  organizerPhone String? @map("organizer_phone")
  notes        String?
  attributes   Json?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@unique([tenantId, code])
  @@index([tenantId, propertyId])
  @@map("reservation_groups")
}

model Reservation {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String            @map("tenant_id") @db.Uuid
  propertyId         String            @map("property_id") @db.Uuid
  // Codigo legible humano ("BCN-A1B2C3")
  code               String
  status             ReservationStatus @default(PENDING)
  // Grupo opcional (Sprint 2 W2)
  groupId            String?           @map("group_id") @db.Uuid
  // Estancia
  arrivalDate        DateTime          @map("arrival_date") @db.Date
  departureDate      DateTime          @map("departure_date") @db.Date
  adults             Int               @default(2)
  children           Int               @default(0)
  // Inventario
  roomTypeId         String            @map("room_type_id") @db.Uuid
  roomId             String?           @map("room_id") @db.Uuid
  // Precio
  ratePlanId         String?           @map("rate_plan_id") @db.Uuid
  totalAmount        Decimal           @default(0) @map("total_amount") @db.Decimal(12, 2)
  currency           String            @default("EUR") @db.Char(3)
  // Origen
  source             ReservationSource @default(DIRECT)
  externalRef        String?           @map("external_ref")
  // Especiales
  specialRequests    String?           @map("special_requests")
  notes              String?
  // Lifecycle timestamps
  checkedInAt        DateTime?         @map("checked_in_at")
  checkedOutAt       DateTime?         @map("checked_out_at")
  cancelledAt        DateTime?         @map("cancelled_at")
  cancellationReason String?           @map("cancellation_reason")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  deletedAt          DateTime?         @map("deleted_at")

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomType RoomType           @relation(fields: [roomTypeId], references: [id])
  room     Room?              @relation(fields: [roomId], references: [id])
  ratePlan RatePlan?          @relation(fields: [ratePlanId], references: [id])
  group    ReservationGroup?  @relation(fields: [groupId], references: [id])
  guests   ReservationGuest[]
  folio    Folio?

  @@unique([tenantId, code])
  @@index([tenantId, propertyId, arrivalDate])
  @@index([tenantId, propertyId, departureDate])
  @@index([tenantId, propertyId, status])
  @@index([tenantId, roomId])
  @@index([tenantId, groupId])
  @@map("reservations")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW

  @@map("reservation_status")
}

enum ReservationSource {
  DIRECT
  WALK_IN
  PHONE
  EMAIL
  BOOKING_COM
  EXPEDIA
  OTHER_OTA
  CORPORATE
  AGENT

  @@map("reservation_source")
}

// Una reserva puede tener varios huespedes (familia, grupo).
model ReservationGuest {
  reservationId String  @map("reservation_id") @db.Uuid
  guestId       String  @map("guest_id") @db.Uuid
  tenantId      String  @map("tenant_id") @db.Uuid
  isPrimary     Boolean @default(false) @map("is_primary")

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  guest       Guest       @relation(fields: [guestId], references: [id], onDelete: Cascade)
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([reservationId, guestId])
  @@index([tenantId, guestId])
  @@map("reservation_guests")
}

// ----------------------------------------------------------------------------
// Folio — cuenta financiera por reserva. Append-only via FolioEntry.
// ----------------------------------------------------------------------------

model Folio {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String      @map("tenant_id") @db.Uuid
  reservationId String      @unique @map("reservation_id") @db.Uuid
  status        FolioStatus @default(OPEN)
  balance       Decimal     @default(0) @db.Decimal(12, 2)
  currency      String      @default("EUR") @db.Char(3)
  closedAt      DateTime?   @map("closed_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservation Reservation  @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  entries     FolioEntry[]

  @@index([tenantId, reservationId])
  @@map("folios")
}

enum FolioStatus {
  OPEN
  CLOSED
  SETTLED

  @@map("folio_status")
}

model FolioEntry {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  folioId        String         @map("folio_id") @db.Uuid
  type           FolioEntryType
  description    String
  amount         Decimal        @db.Decimal(12, 2)
  currency       String         @default("EUR") @db.Char(3)
  postedAt       DateTime       @default(now()) @map("posted_at")
  postedBy       String?        @map("posted_by") @db.Uuid
  idempotencyKey String?        @map("idempotency_key")
  attributes     Json?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  folio  Folio  @relation(fields: [folioId], references: [id], onDelete: Cascade)

  @@unique([folioId, idempotencyKey], map: "folio_entries_folio_id_idempotency_key_key")
  @@index([tenantId, folioId])
  @@index([tenantId, postedAt])
  @@map("folio_entries")
}

enum FolioEntryType {
  CHARGE
  PAYMENT
  DISCOUNT
  TAX
  ADJUSTMENT

  @@map("folio_entry_type")
}

// ----------------------------------------------------------------------------
// Business-day state — locking de operaciones FO sobre dias cerrados.
// ----------------------------------------------------------------------------

model BusinessDayState {
  tenantId        String            @map("tenant_id") @db.Uuid
  propertyId      String            @map("property_id") @db.Uuid
  businessDate    DateTime          @map("business_date") @db.Date
  status          BusinessDayStatus @default(OPEN)
  closedAt        DateTime?         @map("closed_at")
  closedByUserId  String?           @map("closed_by_user_id") @db.Uuid
  reopenedAt      DateTime?         @map("reopened_at")
  reopenedReason  String?           @map("reopened_reason")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([propertyId, businessDate])
  @@index([tenantId, propertyId])
  @@map("business_day_states")
}

enum BusinessDayStatus {
  OPEN
  CLOSED

  @@map("business_day_status")
}

// ----------------------------------------------------------------------------
// SES.HOSPEDAJES — partes diarios para la Guardia Civil (RD 933/2021).
// ----------------------------------------------------------------------------

model SesHospedajesSubmission {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String              @map("tenant_id") @db.Uuid
  propertyId    String              @map("property_id") @db.Uuid
  businessDate  DateTime            @map("business_date") @db.Date
  status        SesSubmissionStatus @default(QUEUED)
  xmlPayload    String?             @map("xml_payload")
  xmlSignature  String?             @map("xml_signature")
  submittedAt   DateTime?           @map("submitted_at")
  responseCode  Int?                @map("response_code")
  responseBody  String?             @map("response_body")
  retryCount    Int                 @default(0) @map("retry_count")
  lastError     String?             @map("last_error")
  nextAttemptAt DateTime?           @map("next_attempt_at")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, businessDate])
  @@index([tenantId, propertyId])
  @@index([status, nextAttemptAt])
  @@map("ses_hospedajes_submissions")
}

enum SesSubmissionStatus {
  QUEUED
  SENT
  FAILED
  DEAD_LETTER

  @@map("ses_submission_status")
}

// ----------------------------------------------------------------------------
// Night Audit (Sprint 3) — cierre nocturno orquestado e idempotente.
// ----------------------------------------------------------------------------

model NightAuditRun {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String              @map("tenant_id") @db.Uuid
  propertyId          String              @map("property_id") @db.Uuid
  businessDate        DateTime            @map("business_date") @db.Date
  status              NightAuditRunStatus @default(PENDING)
  startedAt           DateTime?           @map("started_at")
  completedAt         DateTime?           @map("completed_at")
  lastFailedStep      NightAuditStep?     @map("last_failed_step")
  lastError           String?             @map("last_error")
  startedByUserId     String?             @map("started_by_user_id") @db.Uuid
  completedByUserId   String?             @map("completed_by_user_id") @db.Uuid
  totals              Json?
  attributes          Json?
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  tenant    Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property  Property                @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  steps     NightAuditRunStep[]
  snapshots NightAuditSnapshot[]

  @@unique([propertyId, businessDate])
  @@index([tenantId, propertyId])
  @@index([status])
  @@map("night_audit_runs")
}

enum NightAuditRunStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED

  @@map("night_audit_run_status")
}

enum NightAuditStep {
  POST_ROOM_CHARGES
  POST_TAXES
  POST_PACKAGES
  MARK_NO_SHOWS
  SNAPSHOT_REPORTS
  CLOSE_DAY

  @@map("night_audit_step")
}

model NightAuditRunStep {
  id          String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String                 @map("tenant_id") @db.Uuid
  runId       String                 @map("run_id") @db.Uuid
  step        NightAuditStep
  status      NightAuditStepStatus   @default(PENDING)
  startedAt   DateTime?              @map("started_at")
  completedAt DateTime?              @map("completed_at")
  durationMs  Int?                   @map("duration_ms")
  error       String?
  result      Json?
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  run    NightAuditRun  @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, step])
  @@index([tenantId, runId])
  @@map("night_audit_run_steps")
}

enum NightAuditStepStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED

  @@map("night_audit_step_status")
}

model NightAuditSnapshot {
  id           String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String                @map("tenant_id") @db.Uuid
  propertyId   String                @map("property_id") @db.Uuid
  businessDate DateTime              @map("business_date") @db.Date
  reportType   NightAuditReportType  @map("report_type")
  payload      Json
  generatedAt  DateTime              @default(now()) @map("generated_at")
  runId        String?               @map("run_id") @db.Uuid

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  run      NightAuditRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@unique([propertyId, businessDate, reportType])
  @@index([tenantId, propertyId])
  @@map("night_audit_snapshots")
}

enum NightAuditReportType {
  MANAGER
  IN_HOUSE
  ARRIVALS_DEPARTURES
  REVENUE
  TAX

  @@map("night_audit_report_type")
}

// ----------------------------------------------------------------------------
// Cash drawer reconciliation — gates the Night Audit close.
// ----------------------------------------------------------------------------

model CashDrawerReconciliation {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  propertyId       String   @map("property_id") @db.Uuid
  businessDate     DateTime @map("business_date") @db.Date
  currency         String   @default("EUR") @db.Char(3)
  expectedAmount   Decimal  @default(0) @map("expected_amount") @db.Decimal(12, 2)
  countedAmount    Decimal  @default(0) @map("counted_amount") @db.Decimal(12, 2)
  discrepancy      Decimal  @default(0) @db.Decimal(12, 2)
  toleranceCents   Int      @default(0) @map("tolerance_cents")
  countedByUserId  String?  @map("counted_by_user_id") @db.Uuid
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, businessDate])
  @@index([tenantId, propertyId])
  @@map("cash_drawer_reconciliations")
}

// ----------------------------------------------------------------------------
// Housekeeping (Sprint 4) — tasks, discrepancies, lost & found.
// ----------------------------------------------------------------------------

model HousekeepingTask {
  id                String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String                 @map("tenant_id") @db.Uuid
  propertyId        String                 @map("property_id") @db.Uuid
  roomId            String                 @map("room_id") @db.Uuid
  businessDate      DateTime               @map("business_date") @db.Date
  taskType          HousekeepingTaskType   @default(CHECKOUT_CLEAN) @map("task_type")
  status            HousekeepingTaskStatus @default(PENDING)
  assignedToUserId  String?                @map("assigned_to_user_id") @db.Uuid
  assignedAt        DateTime?              @map("assigned_at")
  startedAt         DateTime?              @map("started_at")
  completedAt       DateTime?              @map("completed_at")
  durationMin       Int?                   @map("duration_min")
  scheduledFor      DateTime?              @map("scheduled_for")
  notes             String?
  result            Json?
  attributes        Json?
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")
  deletedAt         DateTime?              @map("deleted_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  room     Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([propertyId, businessDate, roomId, taskType])
  @@index([tenantId, propertyId, status, scheduledFor])
  @@index([tenantId, assignedToUserId])
  @@index([tenantId, propertyId, businessDate])
  @@map("housekeeping_tasks")
}

enum HousekeepingTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@map("housekeeping_task_status")
}

enum HousekeepingTaskType {
  CHECKOUT_CLEAN
  STAYOVER_CLEAN
  INSPECTION
  MAINTENANCE

  @@map("housekeeping_task_type")
}

// ----------------------------------------------------------------------------
// Lost & Found — objetos olvidados por huespedes. Sprint 4 W3.
// ----------------------------------------------------------------------------

model LostFoundItem {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String          @map("tenant_id") @db.Uuid
  propertyId         String          @map("property_id") @db.Uuid
  roomId             String?         @map("room_id") @db.Uuid
  foundByUserId      String          @map("found_by_user_id") @db.Uuid
  foundAt            DateTime        @default(now()) @map("found_at")
  description        String
  photoBase64        String?         @map("photo_base64")
  photoUrl           String?         @map("photo_url")
  status             LostFoundStatus @default(FOUND)
  claimedByGuestId   String?         @map("claimed_by_guest_id") @db.Uuid
  claimedAt          DateTime?       @map("claimed_at")
  claimedNotes       String?         @map("claimed_notes")
  disposedAt         DateTime?       @map("disposed_at")
  disposedNotes      String?         @map("disposed_notes")
  notes              String?
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  deletedAt          DateTime?       @map("deleted_at")

  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  room           Room?    @relation(fields: [roomId], references: [id], onDelete: SetNull)
  claimedByGuest Guest?   @relation(fields: [claimedByGuestId], references: [id], onDelete: SetNull)

  @@index([tenantId, propertyId, status])
  @@index([tenantId, propertyId, foundAt])
  @@index([tenantId, roomId])
  @@map("lost_found_items")
}

enum LostFoundStatus {
  FOUND
  CLAIMED
  DISPOSED

  @@map("lost_found_status")
}

// ----------------------------------------------------------------------------
// Device pairings — login QR para moviles compartidos. Sprint 4 W4.
// ----------------------------------------------------------------------------

model DevicePairing {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  code             String    @db.Char(12)
  targetUserId     String    @map("target_user_id") @db.Uuid
  issuedByUserId   String    @map("issued_by_user_id") @db.Uuid
  expiresAt        DateTime  @map("expires_at")
  redeemedAt       DateTime? @map("redeemed_at")
  redeemedTokenJti String?   @map("redeemed_token_jti") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([code])
  @@index([tenantId, targetUserId])
  @@index([tenantId, expiresAt])
  @@map("device_pairings")
}
