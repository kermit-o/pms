  @@unique([propertyId, businessDate, reportType])
  @@index([tenantId, propertyId])
  @@map("night_audit_snapshots")
}

enum NightAuditReportType {
  MANAGER
  IN_HOUSE
  ARRIVALS_DEPARTURES
  REVENUE
  TAX

  @@map("night_audit_report_type")
}

// ----------------------------------------------------------------------------
// Anomalies detected during NA (Sprint 6 W2). Solo señales — ADR-020: nada
// se auto-corrige; el supervisor revisa y decide. Ver
// apps/api/src/night-audit/anomaly.service.ts y docs/SPRINT-6-PLAN.md §3.
// ----------------------------------------------------------------------------

model NightAuditAnomaly {
  id               String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String                       @map("tenant_id") @db.Uuid
