// ----------------------------------------------------------------------------
// Night Audit (Sprint 3) — cierre nocturno orquestado e idempotente.
// ----------------------------------------------------------------------------

model NightAuditRun {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String              @map("tenant_id") @db.Uuid
  propertyId          String              @map("property_id") @db.Uuid
  businessDate        DateTime            @map("business_date") @db.Date
  status              NightAuditRunStatus @default(PENDING)
  startedAt           DateTime?           @map("started_at")
  completedAt         DateTime?           @map("completed_at")
  lastFailedStep      NightAuditStep?     @map("last_failed_step")
  lastError           String?             @map("last_error")
  startedByUserId     String?             @map("started_by_user_id") @db.Uuid
  completedByUserId   String?             @map("completed_by_user_id") @db.Uuid
  totals              Json?
  attributes          Json?
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  tenant    Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property  Property                @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  steps     NightAuditRunStep[]
  snapshots NightAuditSnapshot[]
  anomalies NightAuditAnomaly[]

  @@unique([propertyId, businessDate])
  @@index([tenantId, propertyId])
  @@index([status])
  @@map("night_audit_runs")
}

enum NightAuditRunStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED

  @@map("night_audit_run_status")
}

enum NightAuditStep {
  POST_ROOM_CHARGES
  POST_TAXES
  POST_PACKAGES
  MARK_NO_SHOWS
  SNAPSHOT_REPORTS
  DETECT_ANOMALIES
  CLOSE_DAY
  CLEANUP_ORPHAN_TENANTS

  @@map("night_audit_step")
}

model NightAuditRunStep {
  id          String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String                 @map("tenant_id") @db.Uuid
  runId       String                 @map("run_id") @db.Uuid
  step        NightAuditStep
  status      NightAuditStepStatus   @default(PENDING)
  startedAt   DateTime?              @map("started_at")
  completedAt DateTime?              @map("completed_at")
  durationMs  Int?                   @map("duration_ms")
  error       String?
  result      Json?
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  run    NightAuditRun  @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, step])
  @@index([tenantId, runId])
  @@map("night_audit_run_steps")
}

enum NightAuditStepStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED

  @@map("night_audit_step_status")
}

model NightAuditSnapshot {
  id           String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String                @map("tenant_id") @db.Uuid
  propertyId   String                @map("property_id") @db.Uuid
  businessDate DateTime              @map("business_date") @db.Date
  reportType   NightAuditReportType  @map("report_type")
