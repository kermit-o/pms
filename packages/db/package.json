{
  "name": "@pms/db",
  "version": "0.0.0",
  "private": true,
  "description": "PMS database package — Prisma schema, migrations, RLS policies, tenant-scoped client",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "generate": "dotenv -e ../../.env --override -- prisma generate",
    "migrate:dev": "dotenv -e ../../.env --override -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env --override -- prisma migrate deploy",
    "migrate:reset": "dotenv -e ../../.env --override -- prisma migrate reset --force",
    "migrate:status": "dotenv -e ../../.env --override -- prisma migrate status",
    "studio": "dotenv -e ../../.env --override -- prisma studio",
    "seed": "dotenv -e ../../.env --override -- tsx prisma/seed.ts",
    "lint": "eslint \"src/**/*.ts\" \"prisma/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "dotenv -e ../../.env --override -- vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "dotenv": "^16.4.5",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "@types/uuid": "^10.0.0",
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
